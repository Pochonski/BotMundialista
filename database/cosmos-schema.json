{
  "database": "scores365",
  "sharedThroughput": 1000,
  "note": "Free tier limits shared-throughput DBs to 25 containers. State poll keys live inside the games container (id prefixed with `state:`). odds_misc absorbs outrights/bestodds. highlights absorbs team_of_week. catalog absorbs cat_*.",
  "containers": [
    { "name": "catalog", "partitionKey": "/entityType", "defaultTtl": -1, "docIds": "sports-{id}, countries-{id}, competitions-{id}, competitors-{id}", "indexing": { "includedPaths": ["/entityType/?", "/id/?", "/sportId/?", "/countryId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "games", "partitionKey": "/competitionId", "defaultTtl": -1, "docIds": "{id} (game), state:{key} (poll state)", "indexing": { "includedPaths": ["/competitionId/?", "/startTime/?", "/statusGroup/?", "/homeCompetitor/id/?", "/awayCompetitor/id/?", "/stageNum/?", "/groupNum/?", "/seasonNum/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "game_snapshots", "partitionKey": "/gameId", "defaultTtl": 7776000, "docIds": "{gameId}-{lastUpdateId}", "indexing": { "includedPaths": ["/gameId/?", "/lastUpdateId/?", "/fetchedAt/?"], "excludedPaths": ["/_etag/?", "/_self/?", "/statistics/?"] } },
    { "name": "game_overviews", "partitionKey": "/gameId", "defaultTtl": 2592000, "docIds": "{gameId}-{lastUpdateId}", "indexing": { "includedPaths": ["/gameId/?", "/lastUpdateId/?"], "excludedPaths": ["/_etag/?", "/_self/?", "/members/?"] } },
    { "name": "game_pre_stats", "partitionKey": "/gameId", "defaultTtl": -1, "docIds": "{gameId}", "indexing": { "includedPaths": ["/gameId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "game_h2h", "partitionKey": "/gameId", "defaultTtl": -1, "docIds": "{gameId}", "indexing": { "includedPaths": ["/gameId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "standings", "partitionKey": "/competitionId", "defaultTtl": -1, "docIds": "{competitionId}-s{stageNum}-se{seasonNum}", "indexing": { "includedPaths": ["/competitionId/?", "/stageNum/?", "/seasonNum/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "tournament_stats", "partitionKey": "/competitionId", "defaultTtl": -1, "docIds": "{competitionId}-se{seasonNum}-{statId}", "indexing": { "includedPaths": ["/competitionId/?", "/seasonNum/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "predictions", "partitionKey": "/gameId", "defaultTtl": 604800, "docIds": "{gameId}", "indexing": { "includedPaths": ["/gameId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "odds_lines", "partitionKey": "/gameId", "defaultTtl": 7200, "docIds": "{gameId}-{lastUpdateId}", "indexing": { "includedPaths": ["/gameId/?", "/lastUpdateId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "odds_misc", "partitionKey": "/kind", "defaultTtl": 21600, "docIds": "outrights-{competitionId}, bestodds-{competitionId}-{token}", "indexing": { "includedPaths": ["/kind/?", "/competitionId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "athletes", "partitionKey": "/id", "defaultTtl": -1, "docIds": "{id}", "indexing": { "includedPaths": ["/id/?", "/nationalTeamId/?", "/clubId/?", "/name/?", "/nameForURL/?"], "excludedPaths": ["/_etag/?", "/_self/?", "/careerStats/?"] } },
    { "name": "athlete_careers", "partitionKey": "/athleteId", "defaultTtl": -1, "docIds": "{athleteId}-{seasonKey}", "indexing": { "includedPaths": ["/athleteId/?", "/seasonKey/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "athlete_trophies", "partitionKey": "/athleteId", "defaultTtl": -1, "docIds": "{athleteId}", "indexing": { "includedPaths": ["/athleteId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "athlete_transfers", "partitionKey": "/athleteId", "defaultTtl": -1, "docIds": "{athleteId}-{transferId}", "indexing": { "includedPaths": ["/athleteId/?", "/date/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "athlete_games", "partitionKey": "/athleteId", "defaultTtl": -1, "docIds": "{athleteId}-{gameId}", "indexing": { "includedPaths": ["/athleteId/?", "/gameId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "athlete_chart_events", "partitionKey": "/athleteId", "defaultTtl": -1, "docIds": "{athleteId}", "indexing": { "includedPaths": ["/athleteId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "athlete_next_games", "partitionKey": "/athleteId", "defaultTtl": 604800, "docIds": "{athleteId}-{lastUpdateId}", "indexing": { "includedPaths": ["/athleteId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "brackets", "partitionKey": "/competitionId", "defaultTtl": -1, "docIds": "{competitionId}", "indexing": { "includedPaths": ["/competitionId/?", "/seasonNum/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "competition_history", "partitionKey": "/competitionId", "defaultTtl": -1, "docIds": "{competitionId}-se{seasonNum}", "indexing": { "includedPaths": ["/competitionId/?", "/seasonNum/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "fixtures", "partitionKey": "/competitionId", "defaultTtl": 604800, "docIds": "{competitionId}-{token}", "indexing": { "includedPaths": ["/competitionId/?", "/startTime/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "highlights", "partitionKey": "/kind", "defaultTtl": 2592000, "docIds": "tow-{competitionId}-se{seasonNum}-s{stageNum}-r{roundNum}", "indexing": { "includedPaths": ["/kind/?", "/competitionId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "trends", "partitionKey": "/scope", "defaultTtl": 2592000, "docIds": "game-{gameId}-{trendId}, comp-{competitionId}-{trendId}, sport-{sportType}-{trendId}", "indexing": { "includedPaths": ["/scope/?", "/gameId/?", "/competitionId/?", "/sportType/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },
    { "name": "news", "partitionKey": "/scope", "defaultTtl": 2592000, "docIds": "sport-{id}, comp-{id}, game-{id}, athlete-{id}", "indexing": { "includedPaths": ["/scope/?", "/publishDate/?", "/competitionId/?", "/gameId/?", "/athleteId/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "betting_tips", "partitionKey": "/gameId", "defaultTtl": -1, "docIds": "{gameId}-{tipType}", "indexing": { "includedPaths": ["/gameId/?", "/generatedAt/?", "/tipType/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } },

    { "name": "bet_followers", "partitionKey": "/ticketId", "defaultTtl": -1, "docIds": "ticket-{ticketId}", "indexing": { "includedPaths": ["/ticketId/?", "/chatIds/?"], "excludedPaths": ["/_etag/?", "/_self/?"] } }
  ]
}