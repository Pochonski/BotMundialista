{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm --prefix dashboard run build",
  "outputDirectory": "dashboard/dist",
  "installCommand": "npm install && npm install --prefix dashboard --legacy-peer-deps",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
